# AutoGLM-GUI Configuration
# Copy this file to .env and adjust values as needed.
# Priority: CLI args > Environment variables > Config file > Defaults

# ==================== Model Configuration ====================
# Base URL of the model API
AUTOGLM_BASE_URL=http://localhost:8080/v1
# Model name
AUTOGLM_MODEL_NAME=autoglm-phone-9b
# API key for the model API
AUTOGLM_API_KEY=
# Default maximum steps for agent execution
AUTOGLM_DEFAULT_MAX_STEPS=
# Maximum turns for layered agent mode (default: 50, minimum: 1)
AUTOGLM_LAYERED_MAX_TURNS=

# ==================== Decision Model (optional, for layered planner) ====================
AUTOGLM_DECISION_BASE_URL=
AUTOGLM_DECISION_MODEL_NAME=
AUTOGLM_DECISION_API_KEY=

# ==================== ADB Configuration ====================
# Path to adb executable (default: adb from PATH)
AUTOGLM_ADB_PATH=adb

# ==================== Server Configuration ====================
# Host to bind the server to (default: 127.0.0.1)
AUTOGLM_SERVER_HOST=127.0.0.1
# CORS origins (comma-separated, default: http://localhost:3000)
AUTOGLM_CORS_ORIGINS=http://localhost:3000
# Enable web terminal (0 or 1, default: 0)
AUTOGLM_ENABLE_WEB_TERMINAL=0

# ==================== Logging ====================
# Console log level (DEBUG/INFO/WARNING/ERROR/CRITICAL, default: INFO)
AUTOGLM_LOG_LEVEL=INFO
# Log file path (default: logs/autoglm_{time:YYYY-MM-DD}.log)
AUTOGLM_LOG_FILE=logs/autoglm_{time:YYYY-MM-DD}.log
# Disable file logging (set to 1 to disable)
AUTOGLM_NO_LOG_FILE=

# ==================== Tracing ====================
# Enable tracing (default: 1; set to 0/false/no/off to disable)
AUTOGLM_TRACE_ENABLED=1
# Trace file path template (default: logs/trace_{date}.jsonl)
AUTOGLM_TRACE_FILE=logs/trace_{date}.jsonl
# Screenshot capture mode for tracing (artifact/none/base64, default: artifact)
AUTOGLM_TRACE_CAPTURE_SCREENSHOT=artifact

# ==================== Sync Subsystem (Inspection System) ====================
# Server URL for the inspection management server.
# When set, the client will register, heartbeat, and sync with the server.
# When unset, the system runs in standalone mode (no sync).
AUTOGLM_SERVER_URL=
# Example: AUTOGLM_SERVER_URL=https://inspection-server.example.com
